FROM ubuntu:25.04

ARG TOOLCHAIN=gcc-14
ARG MSVC_WINE_DEST=/opt/msvc
ARG MSVC_WINE_REPO_REF=a99ef92104b066f3ccc5937a65608961459f3a48

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV WINEDEBUG=-all
ENV WINEPREFIX=/opt/msvc-wine-prefix
ENV PATH=/opt/msvc/bin/x64:${PATH}
ENV DINGO_TOOLCHAIN=${TOOLCHAIN}

COPY install-msvc-wine.sh /usr/local/bin/install-msvc-wine
COPY print-toolchains.sh /usr/local/bin/dingo-print-toolchains

RUN ["/bin/bash", "-o", "pipefail", "-c", "\
chmod +x /usr/local/bin/install-msvc-wine /usr/local/bin/dingo-print-toolchains && \
set -eux && \
common_packages=( \
    bash-completion \
    ca-certificates \
    ccache \
    cmake \
    curl \
    file \
    git \
    git-lfs \
    jq \
    less \
    locales \
    make \
    ninja-build \
    pkg-config \
    python3 \
    python3-venv \
    rsync \
    software-properties-common \
    tzdata \
    unzip \
    xz-utils \
    zip \
) && \
case \"${TOOLCHAIN}\" in \
    gcc-*) \
        toolchain_version=\"${TOOLCHAIN#gcc-}\" && \
        apt_packages=( \
            \"${common_packages[@]}\" \
            gdb \
            \"cpp-${toolchain_version}\" \
            \"gcc-${toolchain_version}\" \
            \"g++-${toolchain_version}\" \
        ) \
        ;; \
    clang-*) \
        toolchain_version=\"${TOOLCHAIN#clang-}\" && \
        apt_packages=( \
            \"${common_packages[@]}\" \
            gdb \
            \"clang-${toolchain_version}\" \
            \"clang-format-${toolchain_version}\" \
            \"libclang-rt-${toolchain_version}-dev\" \
            \"clang-tidy-${toolchain_version}\" \
            \"clangd-${toolchain_version}\" \
            \"lld-${toolchain_version}\" \
            \"lldb-${toolchain_version}\" \
        ) \
        ;; \
    msvc|msvc-wine) \
        dpkg --add-architecture i386 && \
        apt_packages=( \
            \"${common_packages[@]}\" \
            msitools \
            winbind \
            wine64 \
        ) \
        ;; \
    *) \
        echo \"Unsupported TOOLCHAIN=${TOOLCHAIN}\" >&2 && \
        echo \"Expected gcc-<version>, clang-<version>, or msvc-wine.\" >&2 && \
        exit 1 \
        ;; \
esac && \
apt-get update && \
apt-get install -y --no-install-recommends \"${apt_packages[@]}\" && \
rm -rf /var/lib/apt/lists/* && \
case \"${TOOLCHAIN}\" in \
    gcc-*|clang-*) \
        : \
        ;; \
    msvc|msvc-wine) \
        ln -sf /usr/lib/wine/wine64 /usr/local/bin/wine64 && \
        ln -sf /usr/lib/wine/wine64 /usr/local/bin/wine && \
        /usr/lib/wine/wine64 wineboot --init && \
        while pgrep wineserver > /dev/null; do sleep 1; done && \
        /usr/local/bin/install-msvc-wine \
            --dest \"${MSVC_WINE_DEST}\" \
            --repo-ref \"${MSVC_WINE_REPO_REF}\" \
        ;; \
esac"]

RUN locale-gen en_US.UTF-8 && \
    update-locale LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_UNMANAGED_INSTALL=/usr/local/bin sh

RUN mkdir -p /usr/local/share/dingo-toolchains

WORKDIR /workspace

CMD ["/bin/bash"]
